# Mandatoto environment variables
# Copy to `app/.env` or `app/.env.local` (Vite loads these from the app directory).

# API origin for the frontend (no path suffix). When unset, the app uses `/api/v1`
# and Vite proxies `/api` → http://localhost:8787 (local wrangler + local D1).
# Set this to use the deployed dev Worker + D1 instead (no local API process):
#   VITE_API_URL=https://api.dev.mandato.hu
# Then run: npm run dev:remote   (frontend only), or npm run dev -w app with this in app/.env.local
# CORS on the API allows http://localhost:* origins.
VITE_API_URL=

# Required when using the real dev/prod API with Turnstile (match the Workers secret’s site key).
# VITE_TURNSTILE_SITEKEY=
